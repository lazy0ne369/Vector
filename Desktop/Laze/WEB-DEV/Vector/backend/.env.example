# ================================
# Environment Variables Template
# ================================
# Copy this to .env and fill in your values
# NEVER commit the actual .env file!

# Database
DB_URL=jdbc:mysql://localhost:3306/vector_db?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=your_password_here

# JWT Secret (generate a strong random string)
JWT_SECRET=your_super_secret_jwt_key_at_least_256_bits_long_for_security

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:5175

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
